// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NOTE: All enum columns have been migrated to TEXT in the database.
// We use String types here to match the actual DB column types.

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                       String    @id @default(cuid())
  email                    String    @unique
  passwordHash             String
  name                     String?
  role                     String    @default("OPERATOR")
  organizationId           String?
  vendorId                 String?
  emailVerified            Boolean   @default(false)
  emailVerificationToken   String?
  emailVerificationExpires DateTime?
  isApproved               Boolean   @default(false)
  rejectedAt               DateTime?
  rejectionNote            String?
  isDisabled               Boolean   @default(false)
  disabledAt               DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  organization             Organization?              @relation(fields: [organizationId], references: [id])
  vendor                   Vendor?                    @relation(fields: [vendorId], references: [id])
  jobNotes                 JobNote[]
  notifications            Notification[]
  chatMessages             ChatMessage[]
  auditLogs                AuditLog[]
  passwordResetTokens      PasswordResetToken[]
  requestViews             RequestView[]
  notificationPreferences  UserNotificationPreferences?

  @@index([email])
  @@index([organizationId])
  @@index([vendorId])
  @@index([emailVerificationToken])
}

model Organization {
  id               String   @id @default(cuid())
  name             String
  type             String   @default("OPERATOR")
  contactEmail     String?
  contactPhone     String?
  phone            String?
  email            String?
  address          String?
  plan             String   @default("FREE")
  stripeCustomerId String?
  billingEmail     String?
  planUpdatedAt    DateTime?
  createdAt        DateTime @default(now())

  users            User[]
  properties       Property[]
  serviceRequests  ServiceRequest[]
  invoices         Invoice[]
  jobs             Job[]
  preferredVendors PreferredVendor[]
  platformBills    PlatformBill[]

  @@index([type])
  @@index([plan])
}

model PlatformBill {
  id                String    @id @default(cuid())
  organizationId    String
  periodStart       DateTime
  periodEnd         DateTime
  includedRequests  Int
  completedRequests Int
  billableRequests  Int
  ratePerRequest    Float
  amountCad         Float
  status            String    @default("DRAFT")
  stripeInvoiceId   String?
  stripeInvoiceUrl  String?
  sentAt            DateTime?
  paidAt            DateTime?
  createdAt         DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, periodStart])
  @@index([organizationId])
  @@index([status])
  @@index([periodStart])
}

model Property {
  id             String   @id @default(cuid())
  name           String
  address        String
  description    String?
  organizationId String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization    Organization     @relation(fields: [organizationId], references: [id])
  serviceRequests ServiceRequest[]
  preferredVendors PreferredVendor[]

  @@index([organizationId])
}

model Vendor {
  id              String   @id @default(cuid())
  companyName     String
  contactName     String
  email           String   @unique
  phone           String
  address         String?
  serviceArea          String?
  serviceRadiusKm      Int?
  specialties          String[] @default([])
  isActive             Boolean  @default(true)
  availabilityStatus   String   @default("AVAILABLE")
  availabilityNote     String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user             User[]
  skills           VendorSkill[]
  credentials      VendorCredential[]
  jobs             Job[]
  preferredVendors PreferredVendor[]

  @@index([isActive])
}

model VendorSkill {
  id       String @id @default(cuid())
  vendorId String
  category String

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@unique([vendorId, category])
  @@index([vendorId])
}

model PreferredVendor {
  id             String   @id @default(cuid())
  organizationId String
  propertyId     String?
  category       String
  vendorId       String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  property     Property?    @relation(fields: [propertyId], references: [id])
  vendor       Vendor       @relation(fields: [vendorId], references: [id])

  @@unique([organizationId, propertyId, category])
  @@index([organizationId])
  @@index([propertyId])
  @@index([vendorId])
}

model VendorCredential {
  id               String    @id @default(cuid())
  vendorId         String
  type             String
  credentialNumber String
  expiresAt        DateTime?
  verified         Boolean   @default(false)

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
}

model ServiceRequest {
  id               String   @id @default(cuid())
  referenceNumber  String   @unique
  title            String   @default("")
  description      String
  category         String
  propertyId       String
  organizationId   String
  urgency          String   @default("MEDIUM")
  status           String   @default("SUBMITTED")
  aiTriageSummary  String?
  aiUrgencyScore   Int?
  rejectionReason  String?
  resolvedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  property     Property     @relation(fields: [propertyId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  job          Job?
  invoice      Invoice?
  photos       Photo[]
  chatMessages ChatMessage[]
  aiClassifications AiClassification[]
  requestViews      RequestView[]

  @@index([organizationId])
  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@index([referenceNumber])
}

model Job {
  id                 String    @id @default(cuid())
  serviceRequestId   String    @unique
  vendorId           String
  organizationId     String?
  status             String    @default("OFFERED")
  acceptedAt         DateTime?
  enRouteAt          DateTime?
  arrivedAt          DateTime?
  completedAt        DateTime?
  totalLabourHours   Float?
  totalMaterialsCost Float?
  totalCost          Float?
  vendorNotes        String?
  completionSummary  String?
  isPaused           Boolean   @default(false)
  pauseReason        String?
  estimatedReturnDate DateTime?
  pausedAt           DateTime?
  declineReason      String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id])
  vendor         Vendor         @relation(fields: [vendorId], references: [id])
  organization   Organization?  @relation(fields: [organizationId], references: [id])
  notes          JobNote[]
  photos         JobPhoto[]
  materials      JobMaterial[]
  proofPacket    ProofPacket?

  @@index([serviceRequestId])
  @@index([vendorId])
  @@index([status])
}

model JobNote {
  id        String   @id @default(cuid())
  jobId     String
  userId    String
  text      String
  createdAt DateTime @default(now())

  job    Job  @relation(fields: [jobId], references: [id])
  author User @relation(fields: [userId], references: [id])

  @@index([jobId])
}

model JobPhoto {
  id        String   @id @default(cuid())
  jobId     String
  type      String
  url       String
  caption   String?
  takenAt   DateTime @default(now())
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id])

  @@index([jobId])
}

model Photo {
  id               String   @id @default(cuid())
  serviceRequestId String
  url              String
  type             String   @default("INTAKE")
  latitude         Float?
  longitude        Float?
  takenAt          DateTime @default(now())
  createdAt        DateTime @default(now())

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id])

  @@index([serviceRequestId])
}

model JobMaterial {
  id          String   @id @default(cuid())
  jobId       String
  description String
  quantity    Float
  unitCost    Float
  createdAt   DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id])

  @@index([jobId])
}

model Invoice {
  id               String   @id @default(cuid())
  serviceRequestId String   @unique
  organizationId   String
  invoiceNumber    String   @unique
  amount           Float
  status           String   @default("DRAFT")
  paidAt           DateTime?
  createdAt        DateTime @default(now())

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id])
  organization   Organization   @relation(fields: [organizationId], references: [id])

  @@index([serviceRequestId])
  @@index([organizationId])
  @@index([status])
}

model ProofPacket {
  id          String   @id @default(cuid())
  jobId       String   @unique
  generatedAt DateTime @default(now())
  summary     String?
  pdfUrl      String?

  job Job @relation(fields: [jobId], references: [id])

  @@index([jobId])
}

// Notification type enum (stored as String per project convention)
// Values: JOB_DISPATCHED | JOB_ACCEPTED | JOB_IN_PROGRESS | JOB_DECLINED
//         JOB_PAUSED | JOB_RESUMED | JOB_ENROUTE | JOB_COMPLETED
//         WORK_REJECTED | WORK_VERIFIED | REQUEST_CANCELLED | GENERAL
model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String   @default("GENERAL")
  link      String?
  metadata  Json?    @default("{}")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([read])
  @@index([type])
  @@index([createdAt])
}

model UserNotificationPreferences {
  id                 String   @id @default(cuid())
  userId             String   @unique
  digestEnabled      Boolean  @default(true)
  // DAILY | NONE
  digestFrequency    String   @default("DAILY")
  smsOptOut          Boolean  @default(false)
  emailOptOut        Boolean  @default(false)
  // Used for one-click unsubscribe links in digest emails (no auth required)
  unsubscribeToken   String   @unique @default(cuid())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([unsubscribeToken])
}

model AiClassification {
  id                  String   @id @default(cuid())
  requestId           String
  suggestedCategory   String
  confidence          Float
  reasoning           String
  createdAt           DateTime @default(now())

  request ServiceRequest @relation(fields: [requestId], references: [id])

  @@index([requestId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  requestId String
  userId    String
  content   String
  createdAt DateTime @default(now())

  request ServiceRequest @relation(fields: [requestId], references: [id])
  user    User           @relation(fields: [userId], references: [id])

  @@index([requestId])
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  userId     String?
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model RequestView {
  id        String         @id @default(cuid())
  userId    String
  requestId String
  viewedAt  DateTime       @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  request ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([userId, requestId])
  @@index([userId])
  @@index([requestId])
}

model SystemSettings {
  id        String   @id @default("singleton")
  updatedAt DateTime @updatedAt

  // ── Email notification toggles ──────────────────────────────────────────
  emailVerification          Boolean @default(true)
  emailPasswordReset         Boolean @default(true)
  emailNewRegistration       Boolean @default(true)
  emailAccountApproved       Boolean @default(true)
  emailAccountRejected       Boolean @default(true)
  emailVendorDispatch        Boolean @default(true)
  emailOperatorStatusUpdate  Boolean @default(true)
  emailJobCompletion         Boolean @default(true)
  emailVendorRejection       Boolean @default(true)
  emailAdminRejection        Boolean @default(true)
  emailWelcome               Boolean @default(true)

  // ── Digest settings ─────────────────────────────────────────────────────
  // Master on/off switch for all digest emails.
  digestGlobalEnabled Boolean @default(true)
  // Hour of day (0-23, UTC) when the daily digest cron fires.
  digestSendHour      Int     @default(17)

  // ── BCC settings ────────────────────────────────────────────────────────
  bccEnabled  Boolean @default(false)
  bccAddresses String  @default("")

  // ── SMS redirect (testing failsafe) ─────────────────────────────────────
  // When enabled, ALL outbound SMS are re-routed to smsRedirectNumber instead
  // of the real recipient. Use during system testing to avoid messaging real users.
  smsRedirectEnabled Boolean @default(false)
  smsRedirectNumber  String  @default("")
}
