# ─── Database (Neon Postgres) ─────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true"

# ─── NextAuth ─────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"
# For subdomain testing: set to http://app.dispatchtogo.test:3000 (use .test to avoid HSTS issues)
APP_BASE_URL="https://app.dispatchtogo.com"
# Hostname only (no port/protocol) for middleware subdomain detection
APP_HOST="app.dispatchtogo.com"
# Full URL of the www/marketing site (used in auth page links)
NEXT_PUBLIC_WWW_BASE_URL="https://www.dispatchtogo.com"

# ─── textbee SMS (optional — messages log to console if not set) ─────────────
# Phase 1: use https://api.textbee.dev (cloud, free tier, needs Android device)
# Phase 2: swap to your self-hosted URL e.g. https://sms.dispatchtogo.com
TEXTBEE_API_URL="https://api.textbee.dev"
TEXTBEE_API_KEY=""
TEXTBEE_DEVICE_ID=""

# ─── Sentry Error Tracking (optional) ──────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# ─── AI Triage (optional — uses OpenAI-compatible API) ───────────────────
# Works with: GitHub Copilot proxy, Perplexity Sonar, OpenAI, any compatible API
AI_BASE_URL="https://ai.dispatchtogo.com/v1"
AI_API_KEY="unused"
AI_MODEL="gpt-4o"
AI_TRIAGE_MAX_RETRIES=3  # Number of classify/triage retries on malformed AI response

# ─── Cloudflare Access (if AI/storage proxies are behind CF Access) ──────────
CF_ACCESS_CLIENT_ID=""
CF_ACCESS_CLIENT_SECRET=""

# ─── Photo Storage (S3-compatible — MinIO on Synology, or any S3 provider) ───
S3_ENDPOINT="https://storage.dispatchtogo.com"
S3_BUCKET="dispatchtogo-photos"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION="us-east-1"
S3_PUBLIC_URL="https://storage.dispatchtogo.com/dispatchtogo-photos"

# ─── Email (SMTP — MXroute or any SMTP provider) ─────────────────────────────
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="DispatchToGo <noreply@dispatchtogo.com>"

# ─── Cloudflare Turnstile CAPTCHA ────────────────────────────────────────────
# Generate site + secret keys at: https://dash.cloudflare.com/?to=/:account/turnstile
# Dev test keys (always pass): site=1x00000000000000000000AA  secret=1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ─── Payments ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ─── Legal Documents ─────────────────────────────────────────────────────────
# Displayed on the /terms and /privacy marketing pages.
# LEGAL_OWNER_NAME is the full legal name of the sole proprietor / legal entity.
LEGAL_OWNER_NAME="Jane Smith operating as DispatchToGo"
LEGAL_EFFECTIVE_DATE="March 7, 2026"
# Must also be set as NEXT_PUBLIC_ so it is accessible in client components (e.g. register form links).
NEXT_PUBLIC_LEGAL_EMAIL="contact@dispatchtogo.com"

# ─── Cron / Digest ────────────────────────────────────────────────────────────
# Secret used to authenticate calls to /api/cron/digest.
# Generate with: openssl rand -hex 32
# Vercel: add to project environment variables — the cron schedule is in vercel.json.
# Dokploy HTTP cron: configure a job calling POST https://app.yourdomain.com/api/cron/digest
#   with header "Authorization: Bearer <this value>" on schedule "0 17 * * *".
#   No code changes required when switching from Vercel.
CRON_SECRET=""

# Digest schedule — only used when CRON_MODE=inprocess (node-cron, Dokploy Option B).
# For Vercel / Dokploy HTTP cron, the schedule is set in vercel.json or the Dokploy UI.
# DIGEST_CRON_SCHEDULE="0 17 * * *"

# Set to "inprocess" to run the digest cron inside the Next.js process via node-cron.
# Requires: npm install node-cron — see src/lib/scheduler.ts for full setup instructions.
# CRON_MODE=inprocess